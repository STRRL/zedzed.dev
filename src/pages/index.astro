---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm STRRL</h1>
			<p>
				I'm a software engineer focused on <strong>cloud-native infrastructure</strong>, <strong>AI tooling</strong>, and <strong>SRE practices</strong>.
				I write about the things I build, break, and learn along the way.
			</p>
			<p>
				This is my technical content brand — a place for deep dives, practical insights, and
				honest takes on the infrastructure and tooling landscape.
			</p>
			<ul>
				<li><a href="/blog">Read the blog</a></li>
				<li><a href="/about">About me</a></li>
				<li><a href="https://github.com/STRRL" target="_blank">GitHub</a></li>
				<li><a href="https://strrl.dev" target="_blank">Personal site (strrl.dev)</a></li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
